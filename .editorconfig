[{*.gd,*.gdf}]
indent_style = tab
ij_gdscript_align_after_assignments = true
ij_gdscript_align_assignments = true
ij_gdscript_align_comments = true
ij_gdscript_keep_indents_on_empty_lines = false
ij_gdscript_label_indent_absolute = false
ij_gdscript_label_indent_size = 0
ij_gdscript_lines_after_header = 1
ij_gdscript_lines_after_variable_group = 0
ij_gdscript_lines_around_multiline_var = 1
ij_gdscript_lines_before_func_max = 2
ij_gdscript_lines_before_func_min = 2
ij_gdscript_lines_between_export_groups = 1
ij_gdscript_lines_in_between_variable_group = 0
ij_gdscript_lines_within_suite = 1
ij_gdscript_space_after_colon = true
ij_gdscript_space_after_comma = true
ij_gdscript_space_before_colon = false
ij_gdscript_space_before_comma = false
ij_gdscript_use_relative_indents = false

[{*.har,*.jsb2,*.jsb3,*.json,*.jsonc,*.postman_collection,*.postman_collection.json,*.postman_environment,*.postman_environment.json,.babelrc,.eslintrc,.prettierrc,.stylelintrc,.ws-context,jest.config}]
indent_size = 2
